# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
venv/
build/
dist/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# Logs + temp
*.log
*.bak
*.orig
*.tmp

# Local databases (any future SQLite/etc. dev artifacts)
*.sqlite
*.sqlite3
*.db

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Local AI-assistant state (Claude Code, Cursor, etc.)
.claude/
.cursor/

# Claude Code memory pointer (per-checkout, points to AGENTS.md)
CLAUDE.md

# Environment / secrets
.env
.env.*
.envrc
*.pem
*.key
*.p12
*.pfx
*.crt
secrets.json
credentials.json
*.token
*_secret*

# Runtime state — generated by the server, not committed.
# Keep the directories (via .gitkeep) but ignore generated content.
data/players/*
!data/players/.gitkeep
data/world/*
!data/world/.gitkeep
data/accounts/*
!data/accounts/.gitkeep
